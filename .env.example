# ============================================================
# 配置文件示例 - 复制此文件为 .env 并填入真实值
# ============================================================

# MiniMax API Key（用于 AI 摘要）
# 获取地址：https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# 企业微信群机器人 Webhook URL
# 获取方式：企业微信群 -> 右键群名 -> 添加群机器人 -> 复制 Webhook 地址
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# （可选）如果用飞书机器人，填这里
FEISHU_WEBHOOK_URL=

# （可选）RSSHub 自建实例地址，默认用公共实例
RSSHUB_BASE_URL=https://rsshub.app
